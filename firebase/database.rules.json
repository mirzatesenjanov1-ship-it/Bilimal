{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('teachers/' + auth.uid + '/role').val() == 'admin')",
        ".write": "auth != null && (auth.uid == $uid || root.child('teachers/' + auth.uid + '/role').val() == 'admin')"
      }
    },
    "teachers": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('teachers/' + auth.uid + '/role').val() == 'admin')",
        ".write": "auth != null && (auth.uid == $uid || root.child('teachers/' + auth.uid + '/role').val() == 'admin')"
      }
    },
    "tests": {
      "$teacherId": {
        ".read": "auth != null && (auth.uid == $teacherId || root.child('teachers/' + auth.uid + '/role').val() == 'admin')",
        ".write": "auth != null && (auth.uid == $teacherId || root.child('teachers/' + auth.uid + '/role').val() == 'admin')"
      }
    },
    "publicTests": {
      ".read": "true",
      "$testId": {
        ".write": "auth != null && (root.child('publicTests/' + $testId + '/teacherId').val() == auth.uid || !data.exists() || root.child('teachers/' + auth.uid + '/role').val() == 'admin')"
      }
    },
    "testResults": {
      "$testId": {
        ".read": "auth != null && (root.child('publicTests/' + $testId + '/teacherId').val() == auth.uid || root.child('teachers/' + auth.uid + '/role').val() == 'admin')",
        "$resultId": {
          ".write": "!data.exists() || (auth != null && root.child('teachers/' + auth.uid + '/role').val() == 'admin')"
        }
      }
    },
    "teacherActivity": {
      "$teacherId": {
        ".read": "auth != null && (auth.uid == $teacherId || root.child('teachers/' + auth.uid + '/role').val() == 'admin')",
        ".write": "auth != null && auth.uid == $teacherId"
      }
    }
  }
}
